# Firma interna para los tokens de foto y asistencia. No es una contraseña de usuario.
# En Vercel usa un valor aleatorio de al menos 32 caracteres.
SUMMER_SIGNING_SECRET=replace-with-a-long-random-secret

# Temporada y conceptos financieros oficiales.
SUMMER_YEAR=2026
SUMMER_CYCLE=2026
SUMMER_CONCEPT_IDS=986,987,988
SUMMER_PLANTELES=PREEM,GM,PM,SM,PREET,PT,ST

# aurora | mysql | hybrid
# aurora: consulta el API de Aurora por Bridge.
# mysql: consulta directamente la base financiera.
# hybrid: intenta Aurora y usa MySQL si Aurora no responde.
SUMMER_SOURCE_MODE=aurora
AURORA_BASE_URL=https://aurora.casitaiedis.edu.mx
AURORA_API_TOKEN=replace-with-the-same-token-configured-in-aurora
AURORA_TIMEOUT_MS=12000

# Base propia de Summer Camp: asistencia, asignaciones y edades manuales.
APP_MYSQL_HOST=
APP_MYSQL_PORT=3306
APP_MYSQL_USER=
APP_MYSQL_PASSWORD=
APP_MYSQL_DATABASE=summer_camp
APP_MYSQL_SSL=true

# Solo se usa con SUMMER_SOURCE_MODE=mysql o hybrid.
FINANCIAL_MYSQL_HOST=
FINANCIAL_MYSQL_PORT=3306
FINANCIAL_MYSQL_USER=
FINANCIAL_MYSQL_PASSWORD=
FINANCIAL_MYSQL_DATABASE=sistema_ingresos
FINANCIAL_MYSQL_SSL=true

# Fotos. La carga es diferida y nunca bloquea la lista.
# Si Aurora publica /api/external/v1/summer/students/:matricula/photo, no son necesarias.
STUDENT_PHOTO_BASE_URL=https://matricula.casitaapps.com
STUDENT_PHOTO_API_KEY=

# Solo desarrollo local. En true genera alumnos sin depender de Aurora ni MySQL.
SUMMER_DEMO_MODE=false

# Frecuencias del cliente.
NUXT_PUBLIC_REFRESH_INTERVAL_MS=120000
NUXT_PUBLIC_HEALTH_INTERVAL_MS=45000
